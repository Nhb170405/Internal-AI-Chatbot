# =========================================================
# Factory Chatbot V2 - Environment Example
# Copy this file to .env for local/docker development.
# Do not commit real secrets.
# =========================================================


# =========================================================
# Shared Secrets
# =========================================================

# Required for chat, embedding, RAG, vector indexing/search.
OPENAI_API_KEY=<your-openai-api-key>


# =========================================================
# Local Docker All-In-One
# =========================================================

# Required when docker-compose.yml starts the local SQL Server container.
# SQL Server requires a strong password: at least 8 chars, upper, lower, number, symbol.
MSSQL_SA_PASSWORD=<your-local-sa-password>

# Local Qdrant collection name.
QDRANT_COLLECTION=internal_documents


# =========================================================
# ASP.NET Core Backend
# =========================================================

ASPNETCORE_ENVIRONMENT=Development

# Used when running backend outside docker against Azure SQL.
# docker-compose.yml overrides this with the local sqlserver service connection.
ConnectionStrings__DefaultConnection=Server=tcp:<azure-sql-server>.database.windows.net,1433;Initial Catalog=<database-name>;Persist Security Info=False;User ID=<username>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

OpenAI__BaseUrl=https://api.openai.com/v1
OpenAI__ChatModel=gpt-4.1-mini
OpenAI__EmbeddingModel=text-embedding-3-small
OpenAI__SystemPrompt=You are an internal company assistant. Answer safely and concisely.

# In docker-compose.yml, backend talks to Python through the Docker service name.
# If running backend outside docker, use http://localhost:8000.
PythonService__BaseUrl=http://localhost:8000
PythonService__TimeoutSeconds=180

# File storage provider: local | azureblob
# Local Docker MVP uses local. Cloud deployment should use azureblob.
FileStorage__Provider=local

# Used when FileStorage__Provider=local.
LocalFileStorage__RootPath=storage/uploads

# Used when FileStorage__Provider=azureblob.
AzureBlobStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=<storage-account>;AccountKey=<storage-key>;EndpointSuffix=core.windows.net
AzureBlobStorage__ContainerName=uploaded-documents

# Chart storage used by backend when serving generated chart files.
ChartStorage__RootPath=generated/charts

# File validation.
FileValidation__MaxFileSizeBytes=52428800
FileValidation__AllowedExtensions__0=.txt
FileValidation__AllowedExtensions__1=.pdf
FileValidation__AllowedExtensions__2=.docx
FileValidation__AllowedExtensions__3=.csv
FileValidation__AllowedExtensions__4=.xlsx

# Document retention.
DocumentRetention__DeletedFileRetentionDays=30

# Token budget - currently baseline/deferred.
TokenBudget__Enabled=false


# =========================================================
# Python AI Service
# =========================================================

OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Docker Qdrant URL. In Docker, use service name qdrant, not localhost.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

TESSERACT_LANG=vie+eng
TEMP_FILE_ROOT=/tmp/factory-chatbot
CHART_OUTPUT_DIR=/app/generated/charts


# =========================================================
# Frontend
# =========================================================

# Local docker/dev frontend calls backend through host port 5055.
VITE_API_BASE_URL=http://localhost:5055

# Frontend URL allowed to call backend with cookie credentials.
# Local:
Frontend__AllowedOrigins__0=http://localhost:5173

# Production example:
# Frontend__AllowedOrigins__0=https://your-frontend.azurestaticapps.net