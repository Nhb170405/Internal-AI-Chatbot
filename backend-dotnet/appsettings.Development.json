{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=internal-ai-chatbot;Trusted_Connection=True;TrustServerCertificate=True"
  },
  
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": "",
    "ChatModel": "gpt-4.1-mini",
    "SystemPrompt": "You are a helpful internal company assistant. Answer clearly and concisely."
  },

  "DocumentRetention": {
    "DeletedFileRetentionDays": 30
  },

  "PythonService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 60
  },

  "ChartStorage": {
    "RootPath": "../ai-service-python/generated/charts"
  },

  "LocalFileStorage": {
  "RootPath": "storage/uploads",
  "MaxFileSizeBytes": 20971520,
  "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".csv", ".txt" ]
  },

  "FileStorage": {
  "Provider": "local"
  },

  "AzureBlobStorage": {
  "ConnectionString": "",
  "ContainerName": "uploaded-documents",
  "ReadSasMinutes": 15
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Frontend": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://your-frontend.azurestaticapps.net"
    ]
  },

  "Assistant": {
    "ToolCallingEnabled": false
    }
}
