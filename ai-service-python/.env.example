# Factory Chatbot V2 - Python AI Service
# Copy this file to .env for local development.
# Never commit the real .env file because it contains secrets.

# FastAPI runtime
PYTHON_ENV=Development
HOST=0.0.0.0
PORT=8000

# OpenAI
# Required for embedding and vector search/indexing.
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
# Local Docker default: http://localhost:6333
# Production should use Qdrant Cloud or a secured internal Qdrant endpoint.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=internal_documents

# OCR
# Tesseract language codes. Use "vie+eng" for Vietnamese + English.
# The Docker image/server must have the matching Tesseract language data installed.
TESSERACT_LANG=vie+eng

# Runtime files
# OCR/temp files should be written to a temp folder in production, not committed to Git.
TEMP_FILE_ROOT=/tmp/factory-chatbot

# Chart output
# Current local implementation writes generated charts under ai-service-python/generated/charts.
# Production should expose charts through a backend API or upload them to blob storage.
CHART_OUTPUT_DIR=generated/charts
